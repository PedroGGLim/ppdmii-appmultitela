<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TITULO -->
    <TextView
        android:id="@+id/tituloMegaSena"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="MEGA SENA"
        android:textSize="36sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#1B5E20"
        android:textColor="#FFFFFF"

        app:layout_constraintWidth_percent="0.55"
        app:layout_constraintHeight_percent="0.15"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- CONTAINER DOS NÚMEROS -->
    <LinearLayout
        android:id="@+id/containerNumeros"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="20dp"

        app:layout_constraintTop_toBottomOf="@id/tituloMegaSena"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PRIMEIRA LINHA -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/num1"
                style="@style/NumeroQuadrado"/>

            <TextView
                android:id="@+id/num2"
                style="@style/NumeroQuadrado"/>

            <TextView
                android:id="@+id/num3"
                style="@style/NumeroQuadrado"/>

        </LinearLayout>

        <!-- SEGUNDA LINHA -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/num4"
                style="@style/NumeroQuadrado"/>

            <TextView
                android:id="@+id/num5"
                style="@style/NumeroQuadrado"/>

            <TextView
                android:id="@+id/num6"
                style="@style/NumeroQuadrado"/>

        </LinearLayout>

    </LinearLayout>

    <!-- BOTAO SORTEIO -->
    <Button
        android:id="@+id/btnSorteio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SORTEIO"
        android:textSize="20sp"
        android:padding="14dp"
        android:backgroundTint="#1B5E20"
        android:textColor="#FFFFFF"

        app:layout_constraintTop_toBottomOf="@id/containerNumeros"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- BOTAO RESETAR -->
    <Button
        android:id="@+id/btnRecomecar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RECOMEÇAR"
        android:textSize="16sp"
        android:padding="10dp"
        android:backgroundTint="#B71C1C"
        android:textColor="#FFFFFF"

        app:layout_constraintTop_toBottomOf="@id/btnSorteio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>